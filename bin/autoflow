#!/usr/bin/env bash

set -euo pipefail

source="${BASH_SOURCE[0]}"
while [ -L "$source" ]; do
  dir="$(cd "$(dirname "$source")" && pwd)"
  source="$(readlink "$source")"
  [[ "$source" != /* ]] && source="$dir/$source"
done
SCRIPT_DIR="$(cd "$(dirname "$source")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${REPO_ROOT}/packages/cli/cli-common.sh"
DEFAULT_BOARD_DIR_NAME="$(default_board_dir_name)"

usage() {
  cat <<'EOF'
Autoflow CLI

Usage:
  autoflow tool list [project-root] [board-dir-name]
  autoflow init [project-root] [board-dir-name]
  autoflow install-stop-hook [project-root] [board-dir-name]
  autoflow remove-stop-hook [project-root] [board-dir-name]
  autoflow stop-hook-status [project-root] [board-dir-name]
  autoflow watch [project-root] [board-dir-name] [config-path]
  autoflow watch-bg [project-root] [board-dir-name] [config-path]
  autoflow watch-status [project-root] [board-dir-name]
  autoflow watch-stop [project-root] [board-dir-name]
  autoflow prd create [project-root] [board-dir-name] [--id NNN] [--title text] [--goal text] [--from-file path] [--raw] [--save-handoff] [--force]
  autoflow spec create [project-root] [board-dir-name] [--id NNN] [--title text] [--goal text] [--from-file path] [--raw] [--save-handoff] [--force] (legacy alias)
  autoflow order create [project-root] [board-dir-name] [--id NNN] [--title text] [--request text] [--from-file path] [--scope text] [--allowed-path path]... [--verification command] [--force]
  autoflow run planner [project-root] [board-dir-name] [--runner runner-id] [--dry-run]   # Plan AI (3-runner default)
  autoflow run ticket [project-root] [board-dir-name] [--runner runner-id] [--dry-run]    # Impl AI (3-runner default)
  autoflow run wiki [project-root] [board-dir-name] [--runner runner-id] [--dry-run]      # Wiki AI (3-runner default)
  autoflow run todo [project-root] [board-dir-name] [--runner runner-id] [--dry-run]      # legacy role-pipeline
  autoflow run verifier [project-root] [board-dir-name] [--runner runner-id] [--dry-run]  # legacy role-pipeline
  autoflow run coordinator [project-root] [board-dir-name] [--runner runner-id] [--dry-run]  # legacy
  autoflow run self-improve [project-root] [board-dir-name] [--runner runner-id] [--dry-run]  # trial (disabled by default)
  autoflow wiki update [project-root] [board-dir-name] [--dry-run]
  autoflow wiki lint [project-root] [board-dir-name] [--semantic] [--runner RUNNER_ID]
  autoflow wiki query [project-root] [board-dir-name] --term TEXT [--term TEXT]... [--limit N] [--no-tickets] [--no-handoffs] [--no-snippets] [--synth] [--runner RUNNER_ID]
  autoflow runners list [project-root] [board-dir-name]
  autoflow runners add <runner-id> <role> [project-root] [board-dir-name] key=value...
  autoflow runners remove <runner-id> [project-root] [board-dir-name]
  autoflow runners start <runner-id> [project-root] [board-dir-name]
  autoflow runners stop <runner-id> [project-root] [board-dir-name]
  autoflow runners restart <runner-id> [project-root] [board-dir-name]
  autoflow runners artifacts <runner-id> [project-root] [board-dir-name]
  autoflow runners set <runner-id> [project-root] [board-dir-name] key=value...
  autoflow metrics [project-root] [board-dir-name] [--write]
  autoflow render-heartbeats [project-root] [board-dir-name]
  autoflow status [project-root] [board-dir-name]
  autoflow guard [project-root] [board-dir-name] [--strict]
  autoflow doctor [--fix] [project-root] [board-dir-name]
  autoflow upgrade [project-root] [board-dir-name]
  autoflow help

Examples:
  autoflow tool list /path/to/project
  autoflow init .
  autoflow init /path/to/project
  autoflow init /path/to/project .autoflow
  autoflow install-stop-hook /path/to/project
  autoflow watch-bg /path/to/project
  echo "Build the local runner harness" | autoflow prd create /path/to/project --title "Runner harness"
  echo "Increase body font size by 2px" | autoflow order create /path/to/project --title "Increase body font"
  autoflow run planner /path/to/project --runner planner
  autoflow run ticket /path/to/project --runner worker
  autoflow run wiki /path/to/project --runner wiki
  autoflow run coordinator /path/to/project --runner coordinator-1   # legacy
  autoflow run self-improve /path/to/project --runner self-improve-1  # trial
  autoflow wiki update /path/to/project
  autoflow wiki query /path/to/project --term auth --term session --limit 5 --synth
  autoflow runners list /path/to/project
  autoflow runners add todo-2 todo /path/to/project agent=codex model=gpt-5.2
  autoflow runners set todo-1 /path/to/project agent=codex model=gpt-5.2
  autoflow metrics /path/to/project
  autoflow render-heartbeats /path/to/project
  autoflow status .
  autoflow guard .
  autoflow doctor /path/to/project
  autoflow upgrade /path/to/project
EOF
}

print_tool_catalog() {
  local target_root="${1:-.}"
  local board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
  local project_root board_root

  project_root="$(resolve_project_root_or_die "$target_root")"
  board_root="$(board_root_path "$project_root" "$board_dir_name")"

  cat <<EOF
status=ok
catalog_version=1
project_root=${project_root}
board_root=${board_root}
tool_count=10
tool.1.id=autoflow-tool-list
tool.1.roles=planner,worker,wiki
tool.1.kind=cli
tool.1.entrypoint=bin/autoflow tool list
tool.1.decision_boundary=result_only
tool.1.contract=List the thin Autoflow tool catalog; AI chooses what to call next.
tool.2.id=start-plan
tool.2.roles=planner
tool.2.kind=runtime_script
tool.2.entrypoint=${board_root}/scripts/start-plan.sh
tool.2.decision_boundary=result_only
tool.2.outputs=status,source,replan_skipped.*,board_root,project_root
tool.2.contract=Select the next plan-side board input and emit parseable state only; AI decides planning or recovery meaning.
tool.3.id=start-ticket-owner
tool.3.roles=worker
tool.3.kind=runtime_script
tool.3.entrypoint=${board_root}/scripts/start-ticket-owner.sh
tool.3.decision_boundary=result_only
tool.3.outputs=status,source,board_root,project_root,worktree_status
tool.3.contract=Claim or resume one ticket and expose worktree state only; AI decides implementation, recovery, and merge direction.
tool.4.id=verify-ticket-owner
tool.4.roles=worker
tool.4.kind=runtime_script
tool.4.entrypoint=${board_root}/scripts/verify-ticket-owner.sh
tool.4.decision_boundary=result_only
tool.4.outputs=status,ticket_id,run_file
tool.4.contract=Record verification evidence for a command the AI already ran and judged; the helper does not decide pass or fail.
tool.5.id=finish-ticket-owner
tool.5.roles=worker
tool.5.kind=runtime_script
tool.5.entrypoint=${board_root}/scripts/finish-ticket-owner.sh
tool.5.decision_boundary=result_only
tool.5.outputs=status,outcome,commit_status,log_file
tool.5.contract=Finalize pass or fail bookkeeping after the AI has already decided and, on pass, already merged into PROJECT_ROOT.
tool.6.id=autoflow-guard
tool.6.roles=planner,worker
tool.6.kind=cli
tool.6.entrypoint=bin/autoflow guard
tool.6.decision_boundary=result_only
tool.6.outputs=status,reason,warning.*
tool.6.contract=Validate board invariants and report findings only; AI interprets warnings or repairs markdown.
tool.7.id=autoflow-wiki-query
tool.7.roles=planner,worker,wiki
tool.7.kind=cli
tool.7.entrypoint=bin/autoflow wiki query --term <text> --rag
tool.7.decision_boundary=result_only
tool.7.outputs=status,result_count,match.*,chunk.*
tool.7.contract=Return prior decisions, learnings, and related tickets as memory only; wiki never overrides board stage or pass state.
tool.8.id=run-role
tool.8.roles=planner,worker,wiki
tool.8.kind=cli
tool.8.entrypoint=packages/cli/run-role.sh
tool.8.decision_boundary=result_only
tool.8.outputs=status,runner_status,active_*,board_root,project_root
tool.8.contract=Dispatch one runner tick and surface runtime state only; adapter AI remains the workflow decision maker.
tool.9.id=board-helpers
tool.9.roles=planner,worker,wiki
tool.9.kind=library
tool.9.entrypoint=runtime/board-scripts/common.sh
tool.9.decision_boundary=result_only
tool.9.outputs=board_root,project_root,ticket_paths,field_reads,field_writes
tool.9.contract=Resolve board paths and ticket metadata, and perform narrow board/worktree mutations without choosing policy.
tool.10.id=worktree-helpers
tool.10.roles=planner,worker,wiki
tool.10.kind=library
tool.10.entrypoint=.autoflow/scripts/common.sh
tool.10.decision_boundary=result_only
tool.10.outputs=worktree_status,dirty_scope_conflict,recovery_evidence
tool.10.contract=Report worktree and dirty-root evidence, prepare snapshots, and move board files without deciding workflow meaning.
EOF
}

cmd="${1:-help}"

case "$cmd" in
  tool)
    shift || true
    subcmd="${1:-}"
    case "$subcmd" in
      list)
        shift || true
        print_tool_catalog "${1:-.}" "${2:-$DEFAULT_BOARD_DIR_NAME}"
        ;;
      *)
        echo "Unknown tool command: ${subcmd:-}" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
    esac
    ;;
  init)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/scaffold-project.sh" "$target_root" "$board_dir_name"
    ;;
  install-stop-hook)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/stop-hook-project.sh" install "$target_root" "$board_dir_name"
    ;;
  remove-stop-hook)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/stop-hook-project.sh" remove "$target_root" "$board_dir_name"
    ;;
  stop-hook-status)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/stop-hook-project.sh" status "$target_root" "$board_dir_name"
    ;;
  watch)
    shift || true
    exec "${REPO_ROOT}/packages/cli/watch-project.sh" "$@"
    ;;
  watch-bg)
    shift || true
    exec "${REPO_ROOT}/packages/cli/watch-project.sh" --background "$@"
    ;;
  watch-status)
    shift || true
    exec "${REPO_ROOT}/packages/cli/watch-project.sh" --status "$@"
    ;;
  watch-stop)
    shift || true
    exec "${REPO_ROOT}/packages/cli/watch-project.sh" --stop "$@"
    ;;
  prd|spec)
    shift || true
    exec "${REPO_ROOT}/packages/cli/spec-project.sh" "$@"
    ;;
  order|memo)
    shift || true
    exec "${REPO_ROOT}/packages/cli/memo-project.sh" "$@"
    ;;
  run)
    shift || true
    exec "${REPO_ROOT}/packages/cli/run-role.sh" "$@"
    ;;
  wiki)
    shift || true
    exec "${REPO_ROOT}/packages/cli/wiki-project.sh" "$@"
    ;;
  runners)
    shift || true
    exec "${REPO_ROOT}/packages/cli/runners-project.sh" "$@"
    ;;
  metrics)
    shift || true
    exec "${REPO_ROOT}/packages/cli/metrics-project.sh" "$@"
    ;;
  status)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/status-project.sh" "$target_root" "$board_dir_name"
    ;;
  guard)
    shift || true
    exec "${REPO_ROOT}/packages/cli/guard-project.sh" "$@"
    ;;
  render-heartbeats)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/render-heartbeats.sh" "$target_root" "$board_dir_name"
    ;;
  doctor)
    shift || true
    fix_mode=0
    doctor_args=()
    for arg in "$@"; do
      if [ "$arg" = "--fix" ]; then
        fix_mode=1
      else
        doctor_args+=("$arg")
      fi
    done
    target_root="${doctor_args[0]:-.}"
    board_dir_name="${doctor_args[1]:-$DEFAULT_BOARD_DIR_NAME}"
    AUTOFLOW_DOCTOR_FIX="$fix_mode" exec "${REPO_ROOT}/packages/cli/doctor-project.sh" "$target_root" "$board_dir_name"
    ;;
  upgrade)
    shift || true
    target_root="${1:-.}"
    board_dir_name="${2:-$DEFAULT_BOARD_DIR_NAME}"
    exec "${REPO_ROOT}/packages/cli/upgrade-project.sh" "$target_root" "$board_dir_name"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
