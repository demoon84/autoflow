#!/usr/bin/env bash
# Example project hook — copy to verify-post.sh and chmod +x to enable.
#
# This hook runs AFTER the worker's sanity gate passes but BEFORE the local
# commit. Typical use: emit a summary, capture artifacts to .autoflow/runners/state/,
# notify a desktop tray, etc.

set -euo pipefail

ticket_id="${AUTOFLOW_HOOK_TICKET_ID:-unknown}"
prd_key="${AUTOFLOW_HOOK_PRD_KEY:-unknown}"

echo "[verify-post] ticket=${ticket_id} prd=${prd_key}" >&2

# Example: write a per-ticket marker so downstream tooling knows the worker
# finished cleanly.
artifact_dir="${AUTOFLOW_BOARD_ROOT}/runners/state/post-pass-markers"
mkdir -p "$artifact_dir" 2>/dev/null || true
printf 'ticket=%s prd=%s ts=%s\n' "$ticket_id" "$prd_key" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  >> "$artifact_dir/${ticket_id}.log" 2>/dev/null || true

exit 0
