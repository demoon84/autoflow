#!/usr/bin/env bash
# Example project hook — copy to verify-pre.sh and chmod +x to enable.
#
# This hook runs RIGHT BEFORE the worker's verify command. Use it for fast,
# best-effort guards (lint, format check, static analysis warm-up).
#
# It MUST NOT block the flow on its own — exit non-zero only if the failure
# is truly catastrophic. Otherwise log to stderr and exit 0.

set -euo pipefail

ticket_id="${AUTOFLOW_HOOK_TICKET_ID:-unknown}"
change_type="${AUTOFLOW_HOOK_CHANGE_TYPE:-code}"

echo "[verify-pre] ticket=${ticket_id} change_type=${change_type}" >&2

# Example: skip heavy tasks for docs/cleanup tickets.
case "$change_type" in
  docs|cleanup)
    echo "[verify-pre] skipping pre-checks for ${change_type} ticket" >&2
    exit 0
    ;;
esac

# Example: run a fast typecheck pass.
# pnpm --silent tsc --noEmit || echo "[verify-pre] typecheck warning (non-fatal)" >&2

exit 0
