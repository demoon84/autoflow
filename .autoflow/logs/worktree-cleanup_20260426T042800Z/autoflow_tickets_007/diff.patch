+const ownerFlowStages = ["planning", "claimed", "executing", "verifying", "done"] as const;
+
+function capitalizeAgentName(value: string) {
+  if (!value) {
+    return "";
+  }
+
+  return value.charAt(0).toUpperCase() + value.slice(1);
+}
+
+function displayWorkflowRunnerId(value: string) {
+  const ownerMatch = value.match(/^owner-(\d+)$/);
+  if (ownerMatch) {
+    return `worker-${ownerMatch[1]}`;
+  }
+
+  return value;
+}
+
+function inferRunnerFlowStage(runner: AutoflowRunner) {
+  const fragments = [runner.stateStatus, runner.activeItem, runner.lastResult, runner.lastLogLine]
+    .filter(Boolean)
+    .join(" ")
+    .toLowerCase();
+
+  if (!fragments || runner.stateStatus === "idle") {
+    return "idle";
+  }
+
+  if (/(reject|rejected)/.test(fragments)) {
+    return "rejected";
+  }
+
+  if (/(done|pass|passed|completed|finished)/.test(fragments)) {
+    return "done";
+  }
+
+  if (/(verify|verifying|verifier)/.test(fragments)) {
+    return "verifying";
+  }
+
+  if (/(execut|inprogress|implement)/.test(fragments) || runner.stateStatus === "running") {
+    return "executing";
+  }
+
+  if (/(claim|claimed)/.test(fragments)) {
+    return "claimed";
+  }
+
+  if (/(plan|planning|prepare|spec)/.test(fragments)) {
+    return "planning";
+  }
+
+  return "idle";
+}
+
+function runnerProgressLabel(runner: AutoflowRunner) {
+  const stage = inferRunnerFlowStage(runner);
+
+  if (stage === "rejected") {
+    return "공정률: 거절";
+  }
+
+  if (stage === "idle") {
+    return "공정률: 0%";
+  }
+
+  const stageIndex = ownerFlowStages.indexOf(stage as (typeof ownerFlowStages)[number]);
+  if (stageIndex < 0) {
+    return "공정률: 0%";
+  }
+
+  const progressPercent = Math.round((stageIndex / (ownerFlowStages.length - 1)) * 100);
+  return `공정률: ${progressPercent}%`;
+}
+
 function runnerIsEnabled(value: string) {
   return value ? value === "true" : true;
