node_modules/
dist/
.DS_Store
.idea/
.claude/scheduled_tasks.lock
dogfood-board/.autoflow-upgrade-backups/

# electron-builder / vite 빌드 산출물
apps/desktop/build/

# token-cache 등 metrics 도구가 만드는 임시 백업 (.bak.* timestamps)
.autoflow/metrics/token-cache.tsv.bak.*

# Autoflow watch-board hook process artifacts
.autoflow/logs/hooks/

# Wiki AI scratch output at repo root (replace via .autoflow/wiki/answers/)
/semantic_findings.txt

# Autoflow background / derived data — runner가 자기 일하면서 자동으로 쓰는
# 흔적. git에 추적하면 매 tick dirty가 만들어져 cleanup live-lock을 자극하고,
# wiki commit이 history를 도배한다. 데이터 자체는 보존되며 read는 그대로 동작.
.autoflow/wiki/
!.autoflow/wiki/skills/
!.autoflow/wiki/skills/**
.autoflow/wiki-raw/
.autoflow/telemetry/
.autoflow/runners/state/
.autoflow/tickets/check/
.autoflow/conversations/
.claude/worktrees/

# PRD 7 (2026-05-09): sqlite state ledger snapshot. The schema in
# .autoflow/state-schema/ is checked in; the database file is rebuilt by
# state-db.sh sync from existing markdown/state files.
.autoflow/state.db
.autoflow/state.db-shm
.autoflow/state.db-wal

# PRD 223 (2026-05-09): wiki RAG sqlite FTS5 + BM25 phase 1 index. Already
# covered by .autoflow/runners/state/ above; listed explicitly so future
# refactors that narrow the state/ ignore don't accidentally start tracking
# the index file.
.autoflow/runners/state/wiki-search.db
.autoflow/runners/state/wiki-search.db-shm
.autoflow/runners/state/wiki-search.db-wal

# PRD 229 (2026-05-09/2026-05-12): wiki RAG vector index — sentence-transformers
# model cache and python3 venv. Already covered by .autoflow/runners/state/ above;
# listed explicitly so future refactors that narrow state/ don't accidentally
# start tracking the ~80MB model files.
.autoflow/runners/state/wiki-embed-models/

# Auto-rotated backups (kept locally only)
/.autoflow/metrics/*.before-reset.*
/.autoflow/metrics/*.before-reset.*Z
